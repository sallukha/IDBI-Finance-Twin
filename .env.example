# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Use a long, random value in production.
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/finbuddy?retryWrites=true&w=majority
MONGODB_DB_NAME=finbuddy

# Comma-separated frontend URLs are supported.
CLIENT_ORIGIN=http://localhost:3000

# Netlify build variable; leave empty for same-origin local development.
VITE_API_URL=https://your-backend.onrender.com

# Required for live Gemini responses.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Persistent JSON database directory, relative to the project root or absolute.
DATA_DIR=data
