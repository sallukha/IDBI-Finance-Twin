# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Use a long, random value in production.
JWT_SECRET=replace-with-a-long-random-secret

# Required for live Gemini responses.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Persistent JSON database directory, relative to the project root or absolute.
DATA_DIR=data
